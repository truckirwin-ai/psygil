#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook for Psygil Sync
# Runs safety gates on all staged changes before committing

readonly REPO_ROOT="$(git rev-parse --show-toplevel)"
readonly SYNC_LIB="${REPO_ROOT}/scripts/psygil-sync-lib.sh"

# Source the library
if [[ ! -f "$SYNC_LIB" ]]; then
  echo "ERROR: sync library not found: $SYNC_LIB"
  exit 1
fi

source "$SYNC_LIB"

# Run hard rule scan
if ! hard_rule_scan_staged; then
  echo ""
  echo "COMMIT ABORTED: HARD RULE violations detected in staged changes"
  echo "Please fix the violations and try again."
  exit 1
fi

# Run gitleaks scan
if ! gitleaks_scan_staged; then
  echo ""
  echo "COMMIT ABORTED: gitleaks detected potential secrets in staged changes"
  echo "Please remove secrets and try again."
  exit 1
fi

exit 0
