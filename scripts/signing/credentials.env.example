# Psygil macOS signing credentials template
#
# Copy this file to scripts/signing/credentials.env (gitignored) and fill in
# the four values once your Apple Developer registration completes and you
# have installed the Developer ID Application certificate in Keychain Access.
#
# DO NOT commit credentials.env. It is listed in .gitignore at repo root.
#
# After filling this file, run:
#   scripts/signing/preflight.sh
# to verify everything is in place, then:
#   scripts/signing/sign-and-package.sh
# to produce a signed and notarized .dmg at app/dist/.

# ---------------------------------------------------------------------------
# 1. Developer ID Application certificate identity string
# ---------------------------------------------------------------------------
# After installing the cert in Keychain Access, run:
#   security find-identity -v -p codesigning
# and copy the line that starts with "Developer ID Application:". The string
# below must match EXACTLY, including the team id in parentheses.
APPLE_DEVELOPER_ID="Developer ID Application: Foundry SMB (REPLACE_WITH_TEAM_ID)"

# ---------------------------------------------------------------------------
# 2. Apple Team ID (10 alphanumeric characters)
# ---------------------------------------------------------------------------
# Found at: https://developer.apple.com/account -> Membership details -> Team ID
# Example: J3K8L9M2N4
APPLE_TEAM_ID="REPLACE_WITH_TEAM_ID"

# ---------------------------------------------------------------------------
# 3. Apple ID email (the one you log in to developer.apple.com with)
# ---------------------------------------------------------------------------
APPLE_ID="truckirwin@gmail.com"

# ---------------------------------------------------------------------------
# 4. App-specific password for notarization
# ---------------------------------------------------------------------------
# Generated at: https://appleid.apple.com -> Sign-In and Security ->
#   App-Specific Passwords -> + (label it "Psygil notarization")
# Format: xxxx-xxxx-xxxx-xxxx
# This is NOT your Apple ID password. Regular passwords do not work with notarytool.
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# ---------------------------------------------------------------------------
# Optional: bundle ID override
# ---------------------------------------------------------------------------
# Defaults to com.foundrysmb.psygil (already set in electron-builder.yml).
# Only override if you need a variant (staging, internal testing, etc.).
# APPLE_BUNDLE_ID="com.foundrysmb.psygil"
