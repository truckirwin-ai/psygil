{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent",
      "Task",
      "TodoWrite",
      "TaskOutput",
      "TaskStop",
      "WebFetch",
      "WebSearch",
      "NotebookEdit"
    ],
    "deny": [
      "Bash(rm -rf /*:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ~/*:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf .git:*)",
      "Bash(rm -rf /Users/truckirwin/Desktop/Foundry SMB:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard origin/main:*)",
      "Bash(git reset --hard origin/master:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D main:*)",
      "Bash(git branch -D master:*)",
      "Bash(sudo:*)",
      "Bash(npm publish:*)",
      "Bash(gh release delete:*)",
      "Bash(gh pr close:*)"
    ]
  }
}
