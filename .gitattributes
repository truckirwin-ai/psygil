# Git LFS rules. These apply from the FIRST commit, before any large files land.
# Anything over a few MB, or binary media, gets routed to LFS.

# Media
*.MOV  filter=lfs diff=lfs merge=lfs -text
*.mov  filter=lfs diff=lfs merge=lfs -text
*.mp4  filter=lfs diff=lfs merge=lfs -text
*.m4a  filter=lfs diff=lfs merge=lfs -text
*.mp3  filter=lfs diff=lfs merge=lfs -text
*.wav  filter=lfs diff=lfs merge=lfs -text
*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text

# Documents
*.docx filter=lfs diff=lfs merge=lfs -text
*.pdf  filter=lfs diff=lfs merge=lfs -text
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.pptx filter=lfs diff=lfs merge=lfs -text

# Electron + macOS
*.icns filter=lfs diff=lfs merge=lfs -text
*.dmg  filter=lfs diff=lfs merge=lfs -text
*.app  filter=lfs diff=lfs merge=lfs -text
app.asar filter=lfs diff=lfs merge=lfs -text
Electron\ Framework filter=lfs diff=lfs merge=lfs -text

# Line endings: force LF on text files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.py   text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.sh   text eol=lf
