{
  "name": "psygil-app",
  "version": "0.1.0",
  "description": "Psygil — Forensic Psychology IDE",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "node scripts/electron-rebuild-clean.js",
    "db:migrate": "tsx src/main/db/migrate.ts",
    "db:seed": "tsx src/main/db/seed.ts",
    "db:verify": "tsx src/main/db/verify.ts",
    "db:seed-demo": "tsx src/main/db/seed-demo.ts",
    "demo:walkthrough": "tsx scripts/demo-walkthrough.ts",
    "setup:verify": "tsx scripts/verify-setup.ts",
    "setup:samples": "tsx scripts/generate-samples.ts",
    "setup:verify-import": "tsx scripts/verify-doc-import.ts",
    "license-server:verify": "tsx ../services/license-server/verify.ts",
    "license-server:start": "tsx ../services/license-server/server.ts",
    "dist": "electron-vite build && electron-builder",
    "dist:mac": "electron-vite build && electron-builder --mac --config electron-builder.yml",
    "dist:mac:unsigned": "electron-vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac --config electron-builder.yml -c.mac.identity=null",
    "dist:win": "electron-vite build && electron-builder --win --config electron-builder.yml",
    "dist:linux": "electron-vite build && electron-builder --linux --config electron-builder.yml",
    "dist:dir": "electron-vite build && electron-builder --dir --config electron-builder.yml"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/adm-zip": "^0.5.8",
    "@types/pdf-parse": "^1.1.5",
    "adm-zip": "^0.5.17",
    "argon2": "^0.44.0",
    "better-sqlite3": "file:./shims/better-sqlite3",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "chokidar": "^3.6.0",
    "docx": "^9.6.1",
    "drizzle-orm": "^0.45.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^4.4.168",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "drizzle-kit": "^0.31.10",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "build": {
    "extends": null
  }
}
