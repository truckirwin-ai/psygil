# Flat node_modules layout — required by electron-builder.
# pnpm's default symlink farm causes ELOOP errors when electron-builder
# walks node_modules during packaging (it follows pnpm's self-referencing
# package symlinks). hoisted = flat = npm-compatible layout.
node-linker=hoisted

# Auto-install peer dependencies. electron-vite requires vite as a peer;
# without this, the hoisted layout does not pull it in and `pnpm build`
# fails with ERR_MODULE_NOT_FOUND.
auto-install-peers=true

# Auto-approve known-good build scripts so `pnpm install` doesn't prompt
# in CI / non-interactive shells.
enable-pre-post-scripts=true
